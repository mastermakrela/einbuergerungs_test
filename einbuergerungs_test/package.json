{
	"name": "einbuergerungs-test",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "vite dev --port 5179 --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "oxfmt && prettier --write \"**/*.svelte\"",
		"lint": "oxfmt --check && prettier --check \"**/*.svelte\" && oxlint",
		"lint:fix": "oxfmt && prettier --write \"**/*.svelte\" && oxlint --fix"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.1",
		"@types/node": "^25.6.0",
		"eslint-plugin-svelte": "^3.17.1",
		"knip": "^6.11.0",
		"oxfmt": "^0.48.0",
		"oxlint": "^1.61.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"typescript": "^6.0.3",
		"vite": "^8.0.10"
	},
	"type": "module"
}
